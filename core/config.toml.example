# Copy this to config.toml (same directory as the speaktype binary) and adjust.

hotkey = "ALT+SPACE"

# STT Provider ("whisper" or "groq")
stt_provider = "whisper"
# groq_api_key = "gsk_..."

# The URL of your local whisper.cpp server (if using whisper)
whisper_server_url = "http://127.0.0.1:8080"

scratch_dir = "/tmp/speaktype"

cleanup_service_url = "http://127.0.0.1:8008"
enable_cleanup = true

# Text Injection Strategy: "batch" or "stream"
#
# "batch" (Recommended): 100% reliable and immune to OS autocorrect interference. 
# The AI streams text in the background, then instantly pastes the final result via clipboard (Cmd+V).
#
# "stream": Types out characters one-by-one as they arrive from the AI for a cool real-time visual effect.
# Trade-off: Fast keystroke injection can trigger OS autocorrect and scramble text in apps like Mail.
injection_mode = "batch"
